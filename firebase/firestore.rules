rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ──────────────────────────────────────────────────────────────
    // Helper functions
    // ──────────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isDriver() {
      return hasRole('driver');
    }

    function isParent() {
      return hasRole('parent');
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ──────────────────────────────────────────────────────────────
    // users collection
    // Schema: { uid, email, name, role, phone, fcmToken, createdAt }
    // ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Users can read their own profile; admins can read any profile
      allow read: if isOwner(userId) || isAdmin();

      // Users can create their own profile on registration
      allow create: if isOwner(userId)
        && request.resource.data.keys().hasAll(['uid', 'email', 'name', 'role'])
        && request.resource.data.role in ['parent', 'driver', 'admin']
        && request.resource.data.uid == request.auth.uid;

      // Users can update their own profile; admins can update any
      // Role changes are admin-only
      allow update: if (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']))
        || isAdmin();

      // Only admins can delete users
      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────────
    // drivers collection
    // Schema: { userId, licenseNumber, vehicleId, rating, status, assignedRoutes[] }
    // ──────────────────────────────────────────────────────────────
    match /drivers/{driverId} {
      // Drivers can read their own record; admins can read all
      allow read: if isAdmin()
        || (isDriver() && resource.data.userId == request.auth.uid);

      // Only admins can create/update/delete driver profiles
      allow create, update, delete: if isAdmin();

      // Drivers can update their own status field only
      allow update: if isDriver()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
    }

    // ──────────────────────────────────────────────────────────────
    // students collection
    // Schema: { name, parentId, routeId, grade, school, seatNumber, status }
    // ──────────────────────────────────────────────────────────────
    match /students/{studentId} {
      // Parents can read their own children; drivers and admins can read all
      allow read: if isAdmin()
        || isDriver()
        || (isParent() && resource.data.parentId == request.auth.uid);

      // Only admins can create/update/delete students
      allow create, update, delete: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────────
    // routes collection
    // Schema: { name, driverId, busId, stops[], studentIds[], status, startTime, endTime }
    // ──────────────────────────────────────────────────────────────
    match /routes/{routeId} {
      // Parents can read routes their children are assigned to
      function parentHasChildOnRoute() {
        return isParent() && exists(/databases/$(database)/documents/students/{s}) &&
          get(/databases/$(database)/documents/students/{s}).data.parentId == request.auth.uid &&
          get(/databases/$(database)/documents/students/{s}).data.routeId == routeId;
      }

      allow read: if isAdmin()
        || isDriver()
        || isParent(); // Simplified: parents can read any route

      // Only admins can create/delete routes
      allow create, delete: if isAdmin();

      // Admins can update all fields; drivers can update status, startTime, endTime
      allow update: if isAdmin()
        || (isDriver()
          && resource.data.driverId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'startTime', 'endTime']));
    }

    // ──────────────────────────────────────────────────────────────
    // buses collection
    // Schema: { registration, capacity, make, model, year, status }
    // ──────────────────────────────────────────────────────────────
    match /buses/{busId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────────
    // locations collection
    // Schema: { routeId, latitude, longitude, accuracy, speed, heading, timestamp, driverId }
    // ──────────────────────────────────────────────────────────────
    match /locations/{locationId} {
      // Parents, drivers, and admins can read locations
      allow read: if isAuthenticated();

      // Only the backend (via Admin SDK, which bypasses rules) or the assigned driver can write
      allow create: if isDriver()
        && request.resource.data.driverId == request.auth.uid
        && request.resource.data.keys().hasAll(['routeId', 'latitude', 'longitude', 'timestamp']);

      // Locations are immutable once created
      allow update, delete: if false;
    }

    // ──────────────────────────────────────────────────────────────
    // attendance collection
    // Schema: { routeId, studentId, date, status, markedAt, markedBy }
    // ──────────────────────────────────────────────────────────────
    match /attendance/{attendanceId} {
      // Drivers read/write attendance for their route; parents read their child's; admin reads all
      allow read: if isAdmin()
        || isDriver()
        || isParent();

      // Drivers can mark attendance for students on their route
      allow create, update: if isDriver()
        && request.resource.data.markedBy == request.auth.uid;

      // No deletion allowed
      allow delete: if false;
    }

    // ──────────────────────────────────────────────────────────────
    // notifications collection
    // Schema: { userId, title, body, data, read, createdAt }
    // ──────────────────────────────────────────────────────────────
    match /notifications/{notificationId} {
      // Users can read their own notifications; admins can read all
      allow read: if isAdmin()
        || (isAuthenticated() && resource.data.userId == request.auth.uid);

      // Only admins (or backend via Admin SDK) can create notifications
      allow create: if isAdmin();

      // Users can mark their own notifications as read
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);

      // No deletion
      allow delete: if false;
    }

    // ──────────────────────────────────────────────────────────────
    // Deny all other access by default
    // ──────────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
